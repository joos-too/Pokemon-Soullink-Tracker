# Copy these names into the current operator shell. Do not create a committed
# environment file containing their real values.
SUPABASE_MIGRATION_STAGING_URL=https://staging-supabase.example.com
SUPABASE_MIGRATION_STAGING_APP_URL=https://staging-soullink.example.com
SUPABASE_MIGRATION_STAGING_SERVICE_ROLE_KEY=<server-only-service-role-key>

# Prefer a localhost URL through an SSH tunnel. URL-encode the password.
SUPABASE_MIGRATION_STAGING_DB_URL=postgresql://postgres:<password>@127.0.0.1:55432/postgres

# Only the following values belong in the staging frontend build.
VITE_BACKEND=supabase
VITE_SUPABASE_URL=https://staging-supabase.example.com
VITE_SUPABASE_ANON_KEY=<browser-safe-anon-key>
